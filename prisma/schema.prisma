generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("student") // student, admin
  phone         String?
  faculty       String?
  level         String?
  avatar        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  projects      Project[]
}

model Project {
  id              String   @id @default(cuid())
  refNumber       String   @unique
  projectName     String
  ownerName       String
  ownerEmail      String
  ownerPhone      String
  faculty         String
  level           String
  field           String
  description     String
  problem         String
  targetAudience  String
  addedValue      String
  fundingRequired Float    @default(0)
  stage           String   @default("idea") // idea, prototype, launched
  hasPartner      Boolean  @default(false)
  teamSize        Int      @default(1)
  videoLink       String?
  status          String   @default("review") // review, committee, accepted, rejected, revision, incubated
  score           Float?
  evaluationNotes String?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LandingContent {
  id          String   @id @default(cuid())
  section     String   @unique
  titleAr     String
  titleEn     String
  titleFr     String
  subtitleAr  String?
  subtitleEn  String?
  subtitleFr  String?
  contentAr   String?
  contentEn   String?
  contentFr   String?
  imageUrl    String?
  videoUrl    String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueAr   String?
  valueEn   String?
  valueFr   String?
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  titleAr     String
  titleEn     String
  titleFr     String
  descAr      String?
  descEn      String?
  descFr      String?
  date        DateTime
  location    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  nameFr    String
  logoUrl   String?
  website   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
}
